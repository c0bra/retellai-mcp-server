{
	"name": "@bhann/retellai-mcp-server",
	"version": "1.0.0",
	"type": "module",
	"main": "build/index.js",
	"scripts": {
		"build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
		"prepare": "npm run build",
		"watch": "tsc --watch",
		"inspector": "npx @modelcontextprotocol/inspector build/index.js"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"retell",
		"retellai"
	],
	"author": "Brian Hann",
	"license": "MIT",
	"description": "RetellAi MCP Server",
	"files": [
		"build",
		"README.md",
		".env.sample"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"dotenv": "^16.5.0",
		"retell-sdk": "^4.28.0",
		"zod": "^4.3.6"
	},
	"bin": {
		"retellai-mcp-server": "build/index.js"
	},
	"devDependencies": {},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/c0bra/retellai-mcp-server.git"
	},
	"bugs": {
		"url": "https://github.com/c0bra/retellai-mcp-server/issues"
	},
	"homepage": "https://github.com/c0bra/retellai-mcp-server#readme"
}
